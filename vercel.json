{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "runtime": "python3.9"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    // Explicitly route the root to index.html within frontend
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    // All other frontend assets (like /app.js, /style.css)
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
